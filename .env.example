# === ENVIRONMENT ===
NODE_ENV=development
PORT=3000

# === DATABASE ===
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/pixel-rpg?retryWrites=true&w=majority
MONGODB_POOL_SIZE=50

# === TELEGRAM ===
BOT_TOKEN=123456789:ABCDefGHijKLmnoPQRstUvwxyz
BOT_USERNAME=YourBotUsername
ADMIN_TG_ID=123456789

# === SECURITY ===
ALLOW_INSECURE=0
API_SECRET_KEY=your-secret-key-change-this
JWT_SECRET=your-jwt-secret-change-this

# === FEATURES ===
MAX_PLAYERS_PER_FLOOR=100
BOSS_COOLDOWN_HOURS=24
MARKET_LISTING_TTL_HOURS=48

# === LOGGING ===
LOG_LEVEL=info
SENTRY_DSN=

# === RAILWAY ===
RAILWAY_ENVIRONMENT_NAME=
